# Dataset files
*.csv
*.xlsx
*.json

# Allow reports (exceptions to the rules above)
!outputs/reports/*.csv
!outputs/reports/*.json
!outputs/reports/*.xlsx

# Models and large weights
*.pt
*.h5
*.pkl
*.bin

# Environment and Secrets
*.env
.env

# Python Cache
__pycache__/
*.pyc
*.pyo

# Virtual Environments
venv/
env/
.venv/

# IDE and OS
.DS_Store
.idea/
.vscode/

*.safetensors
*.pth
outputs/results/checkpoint*/
